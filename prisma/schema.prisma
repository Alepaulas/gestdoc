generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  image         String?
  role          String      @default("VIEWER")
  documentos    Documento[]
  auditLogs     AuditLog[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Unidade {
  id        String   @id @default(cuid())
  nome      String
  sigla     String   @unique
  setores   Setor[]
  createdAt DateTime @default(now())
}

model Setor {
  id        String   @id @default(cuid())
  nome      String
  sigla     String
  unidadeId String
  unidade   Unidade  @relation(fields: [unidadeId], references: [id])
  areas     Area[]
  createdAt DateTime @default(now())
  @@index([unidadeId])
}

model Area {
  id         String      @id @default(cuid())
  nome       String
  sigla      String
  setorId    String
  setor      Setor       @relation(fields: [setorId], references: [id])
  documentos Documento[]
  createdAt  DateTime    @default(now())
  @@index([setorId])
}

// Tipos de documento conforme Norma Zero ISGH
// FTI, FFO, FLU, INT, MAN, MAP, MOD, NOR, PLC, POL, PRO, PCG, POP, REG, REL
model TipoDocumento {
  id         String      @id @default(cuid())
  sigla      String      @unique
  nome       String
  nivel      Int         // 1, 2 ou 3 conforme Norma Zero
  cor        String      @default("#1D4ED8")
  documentos Documento[]
}

model ItemONA {
  id         String             @id @default(cuid())
  codigo     String             @unique
  titulo     String
  descricao  String             @db.Text
  nivel      Int
  secao      String
  documentos DocumentoItemONA[]
}

model Documento {
  id               String             @id @default(cuid())
  // Codificação Norma Zero: AAA.XXX.000
  codigo           String             @unique
  titulo           String
  versao           String             @default("00")
  status           String             @default("VIGENTE")
  dataPadronizacao DateTime
  dataRevisao      DateTime
  proximaRevisao   DateTime
  descricao        String?            @db.Text
  observacao       String?            @db.Text
  linkEditavel     String?            // Link do WPS/Google Drive editável
  linkPdf          String?            // Link do PDF assinado
  driveFileId      String?
  tipoId           String
  areaId           String
  responsavelId    String
  tipo             TipoDocumento      @relation(fields: [tipoId], references: [id])
  area             Area               @relation(fields: [areaId], references: [id])
  responsavel      User               @relation(fields: [responsavelId], references: [id])
  itensONA         DocumentoItemONA[]
  revisoes         Revisao[]
  auditLogs        AuditLog[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([tipoId])
  @@index([areaId])
  @@index([responsavelId])
}

model DocumentoItemONA {
  documentoId String
  itemONAId   String
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  itemONA     ItemONA   @relation(fields: [itemONAId], references: [id])
  @@id([documentoId, itemONAId])
  @@index([documentoId])
  @@index([itemONAId])
}

model Revisao {
  id          String    @id @default(cuid())
  documentoId String
  versao      String
  descricao   String?   @db.Text
  dataRevisao DateTime
  aprovadoPor String?
  documento   Documento @relation(fields: [documentoId], references: [id])
  createdAt   DateTime  @default(now())
  @@index([documentoId])
}

model AuditLog {
  id          String     @id @default(cuid())
  acao        String
  descricao   String?
  documentoId String?
  userId      String
  documento   Documento? @relation(fields: [documentoId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
  @@index([documentoId])
  @@index([userId])
}
