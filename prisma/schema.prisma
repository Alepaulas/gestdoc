generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  image         String?
  role          String   @default("VIEWER")
  unidadeId     String?
  papelFluxo    String?  // UNIDADE | REFERENCIA_TECNICA | GESTDOC
  unidade       Unidade? @relation(fields: [unidadeId], references: [id])
  accounts      Account[]
  sessions      Session[]
  documentos    Documento[]
  auditLogs     AuditLog[]
  solicitacoesAbertas Solicitacao[] @relation("SolicitacaoSolicitante")
  etapas        SolicitacaoEtapa[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([unidadeId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model Unidade {
  id        String   @id @default(cuid())
  nome      String
  sigla     String   @unique
  setores   Setor[]
  usuarios  User[]
  solicitacoes Solicitacao[]
  createdAt DateTime @default(now())
}
model Setor {
  id        String   @id @default(cuid())
  nome      String
  sigla     String
  unidadeId String
  unidade   Unidade  @relation(fields: [unidadeId], references: [id])
  areas     Area[]
  createdAt DateTime @default(now())
  @@index([unidadeId])
}

model Area {
  id         String      @id @default(cuid())
  nome       String
  sigla      String
  setorId    String
  setor      Setor       @relation(fields: [setorId], references: [id])
  documentos Documento[]
  createdAt  DateTime    @default(now())
  @@index([setorId])
}

model TipoDocumento {
  id         String      @id @default(cuid())
  sigla      String      @unique
  nome       String
  nivel      Int
  cor        String      @default("#1D4ED8")
  documentos Documento[]
}

model ItemONA {
  id         String             @id @default(cuid())
  codigo     String             @unique
  titulo     String
  descricao  String             @db.Text
  nivel      Int
  secao      String
  documentos DocumentoItemONA[]
}

model Documento {
  id               String             @id @default(cuid())
  codigo           String             @unique
  titulo           String
  versao           String             @default("00")
  status           String             @default("VIGENTE")
  dataPadronizacao DateTime
  dataRevisao      DateTime
  proximaRevisao   DateTime
  descricao        String?            @db.Text
  observacao       String?            @db.Text
  linkEditavel     String?
  linkPdf          String?
  driveFileId      String?
  tipoId           String
  areaId           String
  responsavelId    String
  tipo             TipoDocumento      @relation(fields: [tipoId], references: [id])
  area             Area               @relation(fields: [areaId], references: [id])
  responsavel      User               @relation(fields: [responsavelId], references: [id])
  itensONA         DocumentoItemONA[]
  revisoes         Revisao[]
  auditLogs        AuditLog[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  @@index([tipoId])
  @@index([areaId])
  @@index([responsavelId])
}

model DocumentoItemONA {
  documentoId String
  itemONAId   String
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  itemONA     ItemONA   @relation(fields: [itemONAId], references: [id])
  @@id([documentoId, itemONAId])
  @@index([documentoId])
  @@index([itemONAId])
}

model Revisao {
  id          String    @id @default(cuid())
  documentoId String
  versao      String
  descricao   String?   @db.Text
  dataRevisao DateTime
  aprovadoPor String?
  documento   Documento @relation(fields: [documentoId], references: [id])
  createdAt   DateTime  @default(now())
  @@index([documentoId])
}

model AuditLog {
  id          String     @id @default(cuid())
  acao        String
  descricao   String?
  documentoId String?
  userId      String
  documento   Documento? @relation(fields: [documentoId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
  @@index([documentoId])
  @@index([userId])
}

// ───────────────────────────────────────────────
// Fluxo de Solicitação de Padronização
// ───────────────────────────────────────────────

// Etapas possíveis do fluxo (campo `etapaAtual` em Solicitacao):
//   ABERTA                  -> aguardando triagem da Referência Técnica
//   EM_ANALISE_RT           -> com a Referência Técnica
//   DEVOLVIDA_UNIDADE       -> Referência Técnica não validou, voltou pra Unidade
//   EM_PADRONIZACAO         -> com o GestDoc, padronizando
//   AGUARDANDO_VALIDACAO_UNIDADE -> GestDoc enviou pra Unidade validar o padronizado
//   PUBLICADA               -> GestDoc publicou (etapa final)
//   CANCELADA               -> encerrada sem publicação

// Fluxo: UNIDADE → RT → NUGESP (gera código) → GESTDOC → UNIDADE valida → GESTDOC publica → LISTA MESTRA

model Solicitacao {
  id              String   @id @default(cuid())
  codigo          String   @unique
  titulo          String
  descricao       String?  @db.Text
  tipoRequisicao  String   @default("Elaboração")
  abrangencia     String   @default("Institucional")
  tipoDocumento   String?
  setorSigla      String?
  etapaAtual      String   @default("ABERTA")
  unidadeId       String?
  solicitanteId   String
  numeroDocumento String?
  codigoDocumento String?
  codigoGerado    String?
  elaborador      String?
  aprovador       String?
  versao          String?  @default("00")
  revisao         String?  @default("00")
  criticidade     String?
  linkPublicado   String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  unidade         Unidade? @relation(fields: [unidadeId], references: [id])
  solicitante     User     @relation("SolicitacaoSolicitante", fields: [solicitanteId], references: [id])
  anexos          SolicitacaoAnexo[]
  etapas          SolicitacaoEtapa[]

  @@index([unidadeId])
  @@index([solicitanteId])
  @@index([etapaAtual])
}

// Anexos enviados em qualquer momento do fluxo (abertura, reenvio, padronização, etc.)
model SolicitacaoAnexo {
  id             String      @id @default(cuid())
  solicitacaoId  String
  nome           String
  url            String      @db.Text // link Drive (ou outro storage externo) — nada de binário no banco
  enviadoPorId   String
  etapa          String      // em qual etapa do fluxo foi anexado
  createdAt      DateTime    @default(now())

  solicitacao    Solicitacao @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)

  @@index([solicitacaoId])
}

// Histórico de cada passo do fluxo — dá o "com quem está" e "tempo decorrido"
model SolicitacaoEtapa {
  id             String      @id @default(cuid())
  solicitacaoId  String
  etapa          String      // etapa que foi assumida nesse passo
  acao           String      // ABERTURA | VALIDOU | NAO_VALIDOU | REENVIO | PADRONIZOU | ENVIOU_VALIDACAO | VALIDOU_UNIDADE | PUBLICOU | CANCELOU
  comentario     String?     @db.Text
  responsavelId  String
  createdAt      DateTime    @default(now())

  solicitacao    Solicitacao @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)
  responsavel    User        @relation(fields: [responsavelId], references: [id])

  @@index([solicitacaoId])
  @@index([responsavelId])
}
