# Banco — SQLite para dev, MySQL para produção
DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="mysql://usuario:senha@host:3306/gestdoc"

NEXTAUTH_URL="https://seu-app.vercel.app"
NEXTAUTH_SECRET="gere-string-aleatoria-forte-aqui"

# Google Cloud Console: APIs Drive + Gmail ativadas
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxx"
GOOGLE_DRIVE_FOLDER_ID=""

GMAIL_FROM="gestao.documental@suainstituicao.com.br"
CRON_SECRET="string-secreta-para-o-cron"

# Domínios autorizados — separados por vírgula
# Um domínio:  ALLOWED_DOMAINS=@hospital.com.br
# Vários:      ALLOWED_DOMAINS=@hg.com.br,@upa.com.br,@amb.com.br
# Vazio = permite qualquer domínio (só em dev)
ALLOWED_DOMAINS=@suainstituicao.com.br
